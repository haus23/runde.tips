{
  "name": "@haus23/runde.tips",
  "version": "0.0.26",
  "type": "module",
  "imports": {
    "#*": "./app/*"
  },
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "db:generate": "prisma generate --schema ./db/schema.prisma",
    "db:push": "prisma db push --schema ./db/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema ./db/schema.prisma",
    "db:studio": "prisma studio --schema ./db/schema.prisma",
    "icons:add": "sly add",
    "icons:build": "icons build -i ./icons -o ./app/components/icon/icons --optimize 0",
    "check": "biome check --apply .",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@remix-run/node": "^2.7.2",
    "@remix-run/react": "^2.7.2",
    "@remix-run/serve": "^2.7.2",
    "firebase-admin": "^12.0.0",
    "isbot": "^5.1.0",
    "prisma": "^5.10.2",
    "react": "^18.2.0",
    "react-aria-components": "^1.1.1",
    "react-dom": "^18.2.0",
    "remix-auth": "^3.6.0",
    "remix-auth-totp-dev": "^3.0.0",
    "remix-utils": "^7.5.0",
    "sonner": "^1.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "1.5.3",
    "@radix-ui/colors": "^3.0.0",
    "@remix-run/dev": "^2.7.2",
    "@sly-cli/sly": "^1.8.0",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.58",
    "@types/react-dom": "^18.2.19",
    "clsx": "^2.1.0",
    "remix-flat-routes": "^0.6.4",
    "svg-icons-cli": "^0.0.7",
    "tailwind-merge": "^2.2.1",
    "tailwind-variants": "^0.2.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-react-aria-components": "^1.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}