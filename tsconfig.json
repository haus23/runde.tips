{
  "compilerOptions": {
    // Base
    "target": "ES2023",
    "skipLibCheck": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // Strictness
    "strict": true,

    // React
    "jsx": "react-jsx",

    // Vite as Bundler
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": [
      "@remix-run/node",
      "vite/client",
      "@remix-run/react/future/single-fetch.d.ts"
    ],

    // DX (Shorten the app path)
    "paths": {
      "#*": ["./app/*"]
    }
  }
}
