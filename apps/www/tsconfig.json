{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    // Base
    "target": "ES2022",
    "skipLibCheck": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,

    // Vite as Bundler
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,

    // JSX
    "jsx": "react-jsx",

    // DX
    "paths": {
      "#*": ["./app/*"]
    }
  }
}
