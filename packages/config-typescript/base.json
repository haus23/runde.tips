{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Base",
  "compilerOptions": {
    // Base
    "target": "ES2022",
    "skipLibCheck": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,

    // Vite as Bundler
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true
  }
}
